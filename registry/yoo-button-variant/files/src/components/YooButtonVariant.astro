---
type Variant = "midnight-mesh" | "arctic-mesh" | "orchid-mesh" | "mint-mesh" | "sunset-mesh";

interface VariantStyle {
	className: string;
	background: string;
	shadow: string;
}

interface Props {
	text?: string;
	href?: string;
	variant?: Variant;
	target?: "_self" | "_blank";
	rel?: string;
	className?: string;
	textClass?: string;
	paddingClass?: string;
	roundedClass?: string;
	baseClass?: string;
	background?: string;
	shadow?: string;
}

const {
	text = "Подключиться",
	href = "https://t.me/",
	variant = "arctic-mesh",
	target = "_self",
	rel,
	className = "",
	textClass,
	paddingClass = "px-12 py-4",
	roundedClass = "rounded-lg",
	baseClass = "max-w-fit mx-auto text-lg",
	background,
	shadow,
} = Astro.props;

const variantStyles: Record<Variant, VariantStyle> = {
	"midnight-mesh": {
		className: "text-white",
		background:
			"radial-gradient(120% 140% at 0% 0%, rgba(34,211,238,.7) 0%, rgba(34,211,238,0) 45%), radial-gradient(120% 140% at 100% 0%, rgba(99,102,241,.75) 0%, rgba(99,102,241,0) 45%), linear-gradient(140deg, #0f172a 0%, #1e1b4b 50%, #111827 100%)",
		shadow: "0 10px 40px 0 #0f172a59, 0 3px 8px 0 #312e8159",
	},
	"arctic-mesh": {
		className: "text-white",
		background:
			"radial-gradient(110% 130% at 8% 10%, rgba(56,189,248,.6) 0%, rgba(56,189,248,0) 45%), radial-gradient(110% 130% at 90% 18%, rgba(129,140,248,.62) 0%, rgba(129,140,248,0) 45%), linear-gradient(145deg, #0284c7 0%, #2563eb 50%, #4f46e5 100%)",
		shadow: "0 10px 40px 0 #0369a159, 0 3px 8px 0 #1d4ed859",
	},
	"orchid-mesh": {
		className: "text-white",
		background:
			"radial-gradient(120% 140% at 12% 8%, rgba(236,72,153,.58) 0%, rgba(236,72,153,0) 45%), radial-gradient(120% 140% at 90% 14%, rgba(168,85,247,.64) 0%, rgba(168,85,247,0) 46%), linear-gradient(145deg, #c026d3 0%, #a21caf 50%, #db2777 100%)",
		shadow: "0 10px 40px 0 #a21caf59, 0 3px 8px 0 #be185d59",
	},
	"mint-mesh": {
		className: "text-zinc-900",
		background:
			"radial-gradient(120% 140% at 10% 10%, rgba(34,197,94,.5) 0%, rgba(34,197,94,0) 46%), radial-gradient(120% 140% at 90% 12%, rgba(20,184,166,.58) 0%, rgba(20,184,166,0) 46%), linear-gradient(145deg, #ecfeff 0%, #d1fae5 52%, #a7f3d0 100%)",
		shadow: "0 10px 40px 0 #0f766e40, 0 3px 8px 0 #065f4659",
	},
	"sunset-mesh": {
		className: "text-white",
		background:
			"radial-gradient(120% 140% at 10% 8%, rgba(251,191,36,.65) 0%, rgba(251,191,36,0) 45%), radial-gradient(120% 140% at 90% 14%, rgba(249,115,22,.58) 0%, rgba(249,115,22,0) 45%), linear-gradient(145deg, #ea580c 0%, #f97316 50%, #f59e0b 100%)",
		shadow: "0 10px 40px 0 #ea580c59, 0 3px 8px 0 #d9770659",
	},
};

const style = variantStyles[variant];
const relValue = rel ?? (target === "_blank" ? "noopener noreferrer" : undefined);
const backgroundValue = background ?? style.background;
const shadowValue = shadow ?? style.shadow;
const textClassValue = textClass ?? style.className;
---

<a
	href={href}
	target={target}
	rel={relValue}
	class={`bs ${baseClass} ${roundedClass} ${paddingClass} ${textClassValue} ${className}`}
	style={`--btn-shadow: ${shadowValue}; --btn-bg: ${backgroundValue};`}
>
	{text}
</a>

<style>
	.bs {
		background-image: var(--btn-bg);
		background-size: cover;
		box-shadow: var(--btn-shadow);
	}
</style>
