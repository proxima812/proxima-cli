interface Props {
	variant?: keyof typeof presets;
	class?: string;
	outerClass?: string;
	middleClass?: string;
	innerClass?: string;
	outClassFirst?: string;
	outClassSecond?: string;
}

const {
	variant = "default",
	class: className = "",
	outerClass = "",
	middleClass = "",
	innerClass = "",
	outClassFirst = "",
	outClassSecond = "",
} = Astro.props;

const preset = presets[variant] ?? presets.default;

const rootClass = cn(
	"-m-2 grid max-w-lg grid-cols-1 rounded-[2rem] shadow-[inset_0_0_2px_1px_#ffffff1f] ring-1 ring-black/5",
	preset.outer,
	className,
	outerClass,
	outClassFirst,
);

const middleLayerClass = cn(
	"grid grid-cols-1 rounded-[2rem] p-2 shadow-md shadow-black/5",
	preset.middle,
	middleClass,
	outClassSecond,
);

const innerLayerClass = cn(
	"rounded-3xl p-10 ring-1 ring-black/5 lg:shadow-2xl",
	preset.inner,
	innerClass,
);
---

<div class={rootClass}>
	<div class={middleLayerClass}>
		<div class={innerLayerClass}>
			<slot />
		</div>
	</div>
</div>
