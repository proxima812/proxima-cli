<svg viewBox="0 0 1400 1345" xmlns="http://www.w3.org/2000/svg" class="w-[420px]">
	<style>
		path {
			fill: black;
			stroke: black;
			stroke-width: 6;
			stroke-dasharray: 2000;
			stroke-dashoffset: 2000;
			animation: draw 2s ease forwards;
		}

		path:nth-child(2) {
			animation-delay: 0.2s;
		}
		path:nth-child(3) {
			animation-delay: 0.4s;
		}
		path:nth-child(4) {
			animation-delay: 0.6s;
		}
		path:nth-child(5) {
			animation-delay: 0.8s;
		}
		path:nth-child(6) {
			animation-delay: 1s;
		}

		@keyframes draw {
			to {
				stroke-dashoffset: 0;
			}
		}

		svg {
			animation: logoPulse 6s ease-in-out infinite;
			transform-origin: center;
		}

		@keyframes logoPulse {
			0% {
				transform: scale(1);
			}
			50% {
				transform: scale(1.04);
			}
			100% {
				transform: scale(1);
			}
		}
	</style>

