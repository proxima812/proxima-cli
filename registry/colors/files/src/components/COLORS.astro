<script define:vars={{ cssSnippetMap }}>
	const root = document.getElementById("colors-language-component");
	const buttons = root?.querySelectorAll("[data-lang-btn]");

	const LANG_STORAGE_KEY = "colors-component-lang";
	const allowedLangs = new Set(["en", "ru", "es", "zh", "tt", "kk", "uk"]);

	function applyLang(lang) {
		if (!root || !allowedLangs.has(lang)) return;
		root.setAttribute("data-lang", lang);
		buttons?.forEach((btn) => {
			const isActive = btn.getAttribute("data-lang-btn") === lang;
			btn.setAttribute("aria-pressed", isActive ? "true" : "false");
		});
	}

	try {
		const savedLang = localStorage.getItem(LANG_STORAGE_KEY);
		if (savedLang && allowedLangs.has(savedLang)) applyLang(savedLang);
	} catch {}

	if (root && buttons?.length) {
		buttons.forEach((button) => {
			button.addEventListener("click", () => {
				const lang = button.getAttribute("data-lang-btn");
				if (!lang || !allowedLangs.has(lang)) return;
				applyLang(lang);
				try {
					localStorage.setItem(LANG_STORAGE_KEY, lang);
				} catch {}
			});
		});
	}

	const copyButtons = root?.querySelectorAll("[data-copy-btn]");
	const searchInput = root?.querySelector("[data-search-input]");
	const colorItems = root?.querySelectorAll("[data-color-item]");

	if (searchInput && colorItems?.length) {
		searchInput.addEventListener("input", () => {
			const term = searchInput.value.trim().toLowerCase();
			colorItems.forEach((item) => {
				const name = item.getAttribute("data-color-name") ?? "";
				const isVisible = term === "" || name.includes(term);
				item.style.display = isVisible ? "" : "none";
			});
		});
	}

	async function copyTextToClipboard(value) {
		try {
			await navigator.clipboard.writeText(value);
			return true;
		} catch {
			const textarea = document.createElement("textarea");
			textarea.value = value;
			textarea.style.position = "fixed";
			textarea.style.left = "-9999px";
			document.body.appendChild(textarea);
			textarea.select();
			const ok = document.execCommand("copy");
			document.body.removeChild(textarea);
			return ok;
		}
	}

	if (copyButtons?.length) {
		copyButtons.forEach((button) => {
			button.addEventListener("click", async () => {
				const className = button.getAttribute("data-copy-class");
				if (!className) return;

				const value = cssSnippetMap[className] ?? className;

				const copied = await copyTextToClipboard(value);
				if (!copied) return;

				button.classList.add("is-copied");
				window.setTimeout(() => {
					button.classList.remove("is-copied");
				}, 1500);
			});
		});
	}
</script>
