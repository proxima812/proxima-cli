const emojis = ["✨", "🌿", "🔥", "🌙", "💎", "⚡", "🎯", "🫧"];

function getColorHint(name) {
	const token = name.split("-").find((part) => !skipTokens.has(part) && hintMap[part]);

	return token ? `с нотами ${hintMap[token]}` : "с мягким цветовым переходом";
}

function clampDescription(text) {
	if (text.length < 20) return `${text} в современном стиле`;
	if (text.length <= 70) return text;
	const cut = text.slice(0, 70);
	const lastSpace = cut.lastIndexOf(" ");
	return `${(lastSpace === -1 ? cut : cut.slice(0, Math.max(lastSpace, 20))).trimEnd()}.`;
}

function getColorHintEn(name) {
	const token = name.split("-").find((part) => !skipTokens.has(part) && hintMapEn[part]);

	return token ? `with ${hintMapEn[token]} notes` : "with a soft color transition";
}

function getDescriptionRu(name, id) {
	const tone = tones[id % tones.length];
	const usage = usages[(id * 3 + 1) % usages.length];
	const hint = getColorHint(name);
	const emoji = id % 8 === 0 ? ` ${emojis[(id / 8) % emojis.length]}` : "";
	return clampDescription(`${tone} ${hint} ${usage}${emoji}`);
}

